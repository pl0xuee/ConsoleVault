{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ConsoleVault",
  "version": "0.1.1",
  "identifier": "com.consolevault.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ConsoleVault",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "appimage"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERFRjE4QUFFMzQ2NUJENTYKUldSV3ZXVTByb3J4M2xNNk83eFpkL1NCTjNVekZJNWEvZlBUaE80RlFWZTNpYWQ1UU5md1ZvMkoK",
      "endpoints": [
        "https://github.com/pl0xuee/ConsoleVault/releases/latest/download/latest.json"
      ]
    }
  }
}
